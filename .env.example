# ── SmartHospital Environment Variables ──────────────────────────────────────
# Copy this file to .env, fill in the values, then run: docker compose up -d
# NEVER commit .env to git — it is in .gitignore

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=smarthospital
DB_PASSWORD=CHANGE_ME_strong_db_password

# ── JWT secret ────────────────────────────────────────────────────────────────
# Must be at least 32 characters.
# Generate a strong value:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32_output_here

# ── CORS allowed origins ──────────────────────────────────────────────────────
# Local Docker:    http://localhost
# Oracle Cloud:    http://<your-public-ip>
# Custom domain:   https://yourdomain.com
# Multiple (comma-separated): http://localhost,https://yourdomain.com
CORS_ORIGINS=http://localhost
